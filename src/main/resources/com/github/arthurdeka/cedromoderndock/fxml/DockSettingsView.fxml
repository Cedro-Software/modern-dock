<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.ColorPicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="467.0" prefWidth="582.0" stylesheets="@../css/dockSettings.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.github.arthurdeka.cedromoderndock.controller.SettingsController">
   <children>
      <Label layoutX="14.0" prefHeight="59.0" prefWidth="203.0" text="Dock Settings">
         <font>
            <Font size="32.0" />
         </font>
      </Label>
      <TabPane layoutY="59.0" prefHeight="410.0" prefWidth="582.0" tabClosingPolicy="UNAVAILABLE">
        <tabs>
          <Tab text="Icons">
            <content>
              <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="222.0" prefWidth="558.0">
                     <children>
                        <Button fx:id="addProgramButton" layoutX="308.0" layoutY="30.0" mnemonicParsing="false" onAction="#handleAddProgram" prefHeight="33.0" prefWidth="230.0" text="Add Program" />
                        <ListView fx:id="listView" layoutX="14.0" layoutY="11.0" prefHeight="237.0" prefWidth="283.0" />
                        <Button fx:id="removeProgramButton" disable="true" layoutX="309.0" layoutY="113.0" mnemonicParsing="false" onAction="#handleRemoveProgram" prefHeight="33.0" prefWidth="229.0" text="Remove Selected Item" />
                        <Button fx:id="moveItemUpButton" disable="true" layoutX="14.0" layoutY="259.0" mnemonicParsing="false" onAction="#handleMoveItem" prefHeight="32.0" prefWidth="134.0" text="Move Item Up" />
                        <Button fx:id="moveItemDownButton" disable="true" layoutX="159.0" layoutY="259.0" mnemonicParsing="false" onAction="#handleMoveItem" prefHeight="33.0" prefWidth="139.0" text="Move Item Down" />
                        <Button layoutX="307.0" layoutY="71.0" mnemonicParsing="false" onAction="#openAddWindowsModuleWindow" prefHeight="33.0" prefWidth="231.0" text="Add Windows Module" />
                     </children>
                  </AnchorPane>
            </content>
          </Tab>
          <Tab text="Icons Customization">
            <content>
              <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0">
                     <children>
                        <Label layoutX="14.0" layoutY="25.0" text="Icons Size">
                           <font>
                              <Font size="20.0" />
                           </font>
                        </Label>
                        <Slider fx:id="iconSizeSlider" layoutX="14.0" layoutY="55.0" majorTickUnit="5.0" max="60.0" min="15.0" prefHeight="37.0" prefWidth="406.0" showTickLabels="true" showTickMarks="true" />
                        <Label layoutX="14.0" layoutY="100.0" text="Spacing Between Icons">
                           <font>
                              <Font size="20.0" />
                           </font>
                        </Label>
                        <Slider fx:id="spacingBetweenIconsSlider" layoutX="14.0" layoutY="130.0" majorTickUnit="5.0" max="30.0" prefHeight="37.0" prefWidth="406.0" showTickLabels="true" showTickMarks="true" />
                     </children>
                  </AnchorPane>
            </content>
          </Tab>
            <Tab text="Dock Customization">
               <content>
                  <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0">
                     <children>
                        <Label layoutX="14.0" layoutY="24.0" text="Dock Transparency">
                           <font>
                              <Font size="20.0" />
                           </font>
                        </Label>
                        <Slider fx:id="dockTransparencySlider" layoutX="14.0" layoutY="54.0" majorTickUnit="10.0" minorTickCount="1" prefHeight="37.0" prefWidth="406.0" showTickLabels="true" showTickMarks="true" />
                        <Label layoutX="14.0" layoutY="112.0" text="Border Rounding">
                           <font>
                              <Font size="20.0" />
                           </font>
                        </Label>
                        <Slider fx:id="dockBorderRoundingSlider" layoutX="14.0" layoutY="142.0" majorTickUnit="10.0" max="30.0" minorTickCount="1" prefHeight="37.0" prefWidth="406.0" showTickLabels="true" showTickMarks="true" />
                        <ColorPicker id="dockColorPicker" fx:id="dockColorPicker" layoutX="14.0" layoutY="244.0" onAction="#handleSetDockColor" styleClass="color-picker" stylesheets="@../css/dockSettings.css" />
                        <Label layoutX="14.0" layoutY="207.0" text="Dock Background Color:">
                           <font>
                              <Font size="20.0" />
                           </font>
                        </Label>
                     </children></AnchorPane>
               </content>
            </Tab>
             <Tab text="Dock Positioning">
                <content>
                   <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="320.0" prefWidth="558.0">
                      <children>
                         <Label layoutX="17.0" layoutY="8.0" styleClass="positioning-section-title" text="Positioning Mode" />
                         <AnchorPane layoutX="17.0" layoutY="38.0" prefHeight="54.0" prefWidth="524.0" styleClass="positioning-panel">
                            <children>
                               <RadioButton fx:id="staticPositioningRadio" layoutX="18.0" layoutY="16.0" mnemonicParsing="false" onAction="#handlePositioningModeChange" styleClass="positioning-radio" text="Static positioning" />
                               <RadioButton fx:id="dynamicPositioningRadio" layoutX="228.0" layoutY="16.0" mnemonicParsing="false" onAction="#handlePositioningModeChange" styleClass="positioning-radio" text="Dynamic positioning" />
                            </children>
                         </AnchorPane>
                         <AnchorPane fx:id="staticPositioningPane" layoutX="17.0" layoutY="103.0" prefHeight="240.0" prefWidth="524.0">
                            <children>
                               <AnchorPane layoutX="0.0" layoutY="0.0" prefHeight="90.0" prefWidth="524.0" styleClass="positioning-panel">
                                  <children>
                                     <Label layoutX="16.0" layoutY="10.0" styleClass="positioning-section-title" text="Alignment" />
                                     <Label layoutX="16.0" layoutY="41.0" styleClass="positioning-field-label" text="Vertical" />
                                     <ChoiceBox fx:id="verticalPositionChoiceBox" layoutX="103.0" layoutY="37.0" prefWidth="150.0" styleClass="positioning-choice-box" />
                                     <Label layoutX="284.0" layoutY="41.0" styleClass="positioning-field-label" text="Horizontal" />
                                     <ChoiceBox fx:id="horizontalPositionChoiceBox" layoutX="390.0" layoutY="37.0" prefWidth="118.0" styleClass="positioning-choice-box" />
                                  </children>
                               </AnchorPane>
                               <AnchorPane layoutX="0.0" layoutY="104.0" prefHeight="136.0" prefWidth="524.0" styleClass="positioning-panel">
                                  <children>
                                     <Label layoutX="16.0" layoutY="10.0" styleClass="positioning-section-title" text="Screen Spacing" />
                                     <Label layoutX="16.0" layoutY="41.0" styleClass="positioning-field-label" text="Top" />
                                     <Slider fx:id="topSpacingSlider" layoutX="96.0" layoutY="35.0" majorTickUnit="10.0" max="100.0" prefHeight="37.0" prefWidth="166.0" showTickLabels="true" showTickMarks="true" value="20.0" />
                                     <Label layoutX="282.0" layoutY="41.0" styleClass="positioning-field-label" text="Left" />
                                     <Slider fx:id="leftSpacingSlider" layoutX="362.0" layoutY="35.0" majorTickUnit="10.0" max="100.0" prefHeight="37.0" prefWidth="146.0" showTickLabels="true" showTickMarks="true" value="20.0" />
                                     <Label layoutX="16.0" layoutY="88.0" styleClass="positioning-field-label" text="Right" />
                                     <Slider fx:id="rightSpacingSlider" layoutX="96.0" layoutY="82.0" majorTickUnit="10.0" max="100.0" prefHeight="37.0" prefWidth="166.0" showTickLabels="true" showTickMarks="true" value="20.0" />
                                     <Label layoutX="282.0" layoutY="88.0" styleClass="positioning-field-label" text="Down" />
                                     <Slider fx:id="bottomSpacingSlider" layoutX="362.0" layoutY="82.0" majorTickUnit="10.0" max="100.0" prefHeight="37.0" prefWidth="146.0" showTickLabels="true" showTickMarks="true" value="20.0" />
                                  </children>
                               </AnchorPane>
                            </children>
                         </AnchorPane>
                         <AnchorPane fx:id="dynamicPositioningPane" layoutX="17.0" layoutY="103.0" prefHeight="240.0" prefWidth="524.0">
                            <children>
                               <AnchorPane layoutX="0.0" layoutY="0.0" prefHeight="240.0" prefWidth="524.0" styleClass="positioning-panel">
                                  <children>
                                     <Label layoutX="16.0" layoutY="10.0" styleClass="positioning-section-title" text="Dynamic Positioning" />
                                     <Label alignment="CENTER" layoutX="16.0" layoutY="39.0" prefHeight="18.0" prefWidth="492.0" styleClass="positioning-helper" text="Drag the dock freely on the screen to place it wherever you want." textAlignment="CENTER" />
                                     <ImageView fitHeight="170.0" fitWidth="320.0" layoutX="102.0" layoutY="61.0" pickOnBounds="true" preserveRatio="true">
                                        <image>
                                           <Image url="@../icons/positioning.png" />
                                        </image>
                                     </ImageView>
                                  </children>
                               </AnchorPane>
                            </children>
                         </AnchorPane>
                      </children></AnchorPane>
                </content>
             </Tab>
            <Tab text="General">
               <content>
                  <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0">
                     <children>
                        <ImageView fitHeight="63.0" fitWidth="252.0" layoutX="166.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@../icons/logo.png" />
                           </image>
                        </ImageView>
                        <Label alignment="CENTER" layoutY="91.0" prefHeight="29.0" prefWidth="531.0" styleClass="general-label" text="Cedro Software Modern Dock - Version fx1.0 - 07/2025" textAlignment="CENTER">
                           <font>
                              <Font size="20.0" />
                           </font>
                        </Label>
                        <Label alignment="CENTER" layoutX="1.0" layoutY="109.0" prefHeight="29.0" prefWidth="531.0" styleClass="general-label" text="www.visual11themes.win" textAlignment="CENTER">
                           <font>
                              <Font size="20.0" />
                           </font>
                        </Label>
                        <Label alignment="CENTER" layoutX="2.0" layoutY="178.0" prefHeight="29.0" prefWidth="531.0" styleClass="general-label" text="Repository: github.com/arthurdeka/cedro-modern-dock" textAlignment="CENTER">
                           <font>
                              <Font size="20.0" />
                           </font>
                        </Label>
                        <Label alignment="CENTER" layoutX="4.0" layoutY="159.0" prefHeight="29.0" prefWidth="531.0" styleClass="general-label" text="Contact: github.com/arthurdeka" textAlignment="CENTER">
                           <font>
                              <Font size="20.0" />
                           </font>
                        </Label>
                        <Label alignment="CENTER" layoutX="4.0" layoutY="228.0" prefHeight="29.0" prefWidth="531.0" styleClass="general-label" text="Free and Open-Source Software" textAlignment="CENTER">
                           <font>
                              <Font size="20.0" />
                           </font>
                        </Label>
                        <Button fx:id="addProgramButton1" layoutX="159.0" layoutY="273.0" mnemonicParsing="false" onAction="#openAknowledgementsWindow" prefHeight="33.0" prefWidth="230.0" text="Acknowledgements" />
                     </children></AnchorPane>
               </content>
            </Tab>
        </tabs>
      </TabPane>
   </children>
</AnchorPane>
